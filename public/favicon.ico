<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100%" height="100%">
  <!-- Beautiful brand slate-blue-gray background matching the image exactly -->
  <rect width="100" height="100" rx="22" fill="#88A2B2" />
  
  <!-- The orange-golden stylized gateway and rising feedback elements from the emblem -->
  <g transform="translate(4, 2)">
    <!-- Main Arch (terracotta orange) -->
    <path
      d="M22 84V44C22 30.2 32.2 19 46 19C59.8 19 70 30.2 70 44V84H56V44C56 38.5 51.5 34 46 34C40.5 34 36 38.5 36 44V84H22Z"
      fill="#D66C3E"
    />
    <!-- 3D Bevel/Highlight layer (sand gold highlight overlay for the right-side highlight in the image) -->
    <path
      d="M46 19C54 19 61 24 66 31C61 25 54 22 46 22V19Z"
      fill="#E4BC7A"
    />
    <path
      d="M46 34C51.5 34 56 38.5 56 44V84H50V44C50 41.8 48.2 40 46 40V34Z"
      fill="#E4BC7A"
    />
    
    <!-- The soft teal rising feedback swirl / dot -->
    <path
      d="M36 84C36 64 45 52 66 52"
      stroke="#61C2D4"
      stroke-width="5"
      stroke-linecap="round"
    />
    <circle cx="66" cy="52" r="5" fill="#61C2D4" />
  </g>
</svg>
